{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://polyglot-codebase-llm/schemas/agent-run.schema.json",
  "title": "Baseline Agent Run Result",
  "description": "One (agent, bug, run) result from Step 1.3 baseline evaluation. JSONL stream — one per line in results.jsonl.",
  "type": "object",
  "required": [
    "run_id",
    "bug_id",
    "agent_name",
    "agent_commit",
    "llm_model",
    "status",
    "started_at",
    "duration_seconds",
    "tokens_input",
    "tokens_output",
    "schema_version"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Stable id for this run: <agent>-<bug_id>-<ISO date>"
    },
    "bug_id": {
      "type": "string",
      "description": "FK to bug-annotation.schema.json#bug_id"
    },
    "agent_name": {
      "type": "string",
      "enum": ["iSWE-Agent", "MASAI", "SWE-agent", "AutoCodeRover", "other"]
    },
    "agent_commit": {
      "type": "string",
      "description": "Git SHA of the agent code used"
    },
    "llm_model": {
      "type": "string",
      "description": "Model identifier, e.g., 'claude-sonnet-4-6', 'gpt-4o-2024-08-06'"
    },
    "config_path": {
      "type": "string",
      "description": "Relative path to the YAML config used for this run"
    },
    "status": {
      "type": "string",
      "enum": ["resolved", "failed", "timed-out", "errored"],
      "description": "resolved = tests pass; failed = ran to completion but tests fail; timed-out = exceeded cap; errored = harness crash"
    },
    "patch_diff": {
      "type": ["string", "null"],
      "description": "Unified diff produced by the agent; null if no patch"
    },
    "tests_passed": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "tests_failed": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "failure_mode": {
      "type": ["string", "null"],
      "enum": [
        "localization",
        "cross-language-blind",
        "patch-quality",
        "test-execution",
        "other",
        null
      ],
      "description": "Qualitative categorization of the failure (null for resolved runs)"
    },
    "failure_notes": {
      "type": ["string", "null"],
      "description": "Free-form notes from the trajectory analysis"
    },
    "started_at": { "type": "string", "format": "date-time" },
    "duration_seconds": { "type": "number", "minimum": 0 },
    "tokens_input": { "type": "integer", "minimum": 0 },
    "tokens_output": { "type": "integer", "minimum": 0 },
    "estimated_cost_usd": { "type": "number", "minimum": 0 },
    "trajectory_path": {
      "type": ["string", "null"],
      "description": "Path to the saved trajectory log if available"
    },
    "schema_version": { "type": "string", "const": "1.0" }
  },
  "additionalProperties": false
}
